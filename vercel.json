{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    { 
      "source": "/api/(.*)", 
      "destination": "/api/index" 
    },
    { 
      "source": "/((?!api).*)", 
      "destination": "/" 
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
